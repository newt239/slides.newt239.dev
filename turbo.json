{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "inputs": [
        "slides.md",
        "og-image.png",
        "package.json",
        "public/**",
        "theme/**",
        "pages/**",
        "components/**",
        "snippets/**",
        "src/**",
        "index.html",
        "vite.config.ts",
        "tsconfig*.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "export": {
      "cache": false,
      "outputs": ["dist/**"]
    }
  }
}
