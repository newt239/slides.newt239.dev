{
  "redirects": [
    {
      "source": "/example/:path*",
      "destination": "/slides/example/:path*",
      "permanent": true
    },
    {
      "source": "/what-is-accesibility/:path*",
      "destination": "/slides/what-is-accessibility/:path*",
      "permanent": true
    },
    {
      "source": "/digicre-advent-calender-2025/:path*",
      "destination": "/slides/digicre-advent-calender-2025/:path*",
      "permanent": true
    },
    {
      "source": "/slides/intoroducing-until-hidden/:path*",
      "destination": "/slides/introducing-until-hidden/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1/index.html"
    }
  ]
}
